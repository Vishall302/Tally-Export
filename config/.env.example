# Copy this file to `.env` and fill in your real key.
# `.env` is ignored by git (add it to .gitignore if not already).
#
# The wrapper / filter scripts read this via your shell — either:
#   export $(grep -v '^#' .env | xargs)
#   python tds_expense_wrapper.py
# or use a tool like direnv / dotenv to auto-load it.
#
# Get an API key at: https://console.anthropic.com/

ANTHROPIC_API_KEY=your_anthropic_api_key_here
